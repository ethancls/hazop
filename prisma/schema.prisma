// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  avatar        String?
  passwordHash  String
  platformRole  PlatformRole @default(USER)
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sessions      Session[]
  memberships   OrganizationMember[]
  teamMembers   TeamMember[]
  invitationsSent Invitation[] @relation("InvitedBy")
  projects      Project[]
  deviations    Deviation[]
  passwordResetTokens PasswordResetToken[]
  deviationAssignments DeviationAssignment[]
  comments      DeviationComment[]
  activities    ActivityLog[]
  notificationPreferences NotificationPreference?

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

enum PlatformRole {
  SUPER_ADMIN
  ADMIN
  USER
}

// ============================================================================
// ORGANIZATIONS
// ============================================================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members     OrganizationMember[]
  teams       Team[]
  projects    Project[]
  invitations Invitation[]
  settings    OrganizationSettings?
  aiSettings  AISettings?

  @@index([slug])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  joinedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model OrganizationSettings {
  id                   String  @id @default(cuid())
  organizationId       String  @unique
  allowMemberInvites   Boolean @default(false)
  requireAdminApproval Boolean @default(false)
  notifyOnMemberJoin   Boolean @default(true)
  notifyOnProjectCreate Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ============================================================================
// AI CONFIGURATION
// ============================================================================

model AISettings {
  id             String      @id @default(cuid())
  organizationId String      @unique
  provider       AIProvider  @default(OPENAI)
  apiKey         String?     // Encrypted API key
  model          String?     // Model name (e.g., gpt-4, claude-3, gemini-pro)
  baseUrl        String?     // Base URL for provider (e.g., Ollama server URL)
  enabled        Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum AIProvider {
  OPENAI
  ANTHROPIC
  GOOGLE
  OLLAMA
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ============================================================================
// TEAMS
// ============================================================================

model Team {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String   @default("#3b82f6")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      TeamMember[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

enum TeamRole {
  LEAD
  MEMBER
}

// ============================================================================
// INVITATIONS
// ============================================================================

model Invitation {
  id             String   @id @default(cuid())
  email          String
  organizationId String
  role           OrganizationRole @default(MEMBER)
  token          String   @unique
  status         InvitationStatus @default(PENDING)
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([token])
  @@index([email])
  @@index([organizationId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
  EXPIRED
}

// ============================================================================
// HAZOP PROJECTS
// ============================================================================

model Project {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String
  description        String?
  processDescription String?  // Detailed process description for HAZOP
  status             ProjectStatus @default(DRAFT)
  createdById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])
  nodes        Node[]

  @@index([organizationId])
  @@index([createdById])
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  REVIEW
  COMPLETED
  ARCHIVED
}

// ============================================================================
// HAZOP NODES & DEVIATIONS
// ============================================================================

model Node {
  id           String   @id @default(cuid())
  projectId    String
  name         String
  description  String?
  designIntent String?
  equipment    String?  // Equipment tag/identifier
  parameters   String?  // JSON string for flexible parameters
  position     String?  // JSON string for flow diagram position {x, y}
  nodeType     String?  // Template type: pump, vessel, heat_exchanger, valve, etc.
  color        String?  // Node color for flow diagram
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deviations Deviation[]
  connections NodeConnection[] @relation("SourceNode")
  incomingConnections NodeConnection[] @relation("TargetNode")

  @@index([projectId])
}

model NodeConnection {
  id        String   @id @default(cuid())
  sourceId  String
  targetId  String
  label     String?  // Connection label (e.g., "Feed", "Product")
  createdAt DateTime @default(now())

  source Node @relation("SourceNode", fields: [sourceId], references: [id], onDelete: Cascade)
  target Node @relation("TargetNode", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@index([sourceId])
  @@index([targetId])
}

model Deviation {
  id              String   @id @default(cuid())
  nodeId          String
  guideWord       String   // NO, MORE, LESS, REVERSE, etc.
  parameter       String   // Flow, Temperature, Pressure, etc.
  deviation       String   // Computed: guideWord + parameter
  cause           String?  // Can be used for simple text or JSON array
  consequence     String?  // Can be used for simple text or JSON array
  safeguards      String?  // Can be used for simple text or JSON array
  recommendations String?  // Can be used for simple text or JSON array
  likelihood      Int?     // 1-5
  severity        Int?     // 1-5
  riskLevel       RiskLevel?
  status          DeviationStatus @default(OPEN)
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  node              Node                 @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  createdBy         User                 @relation(fields: [createdById], references: [id])
  causesDetailed    DeviationCause[]
  consequencesDetailed DeviationConsequence[]
  safeguardsDetailed   DeviationSafeguard[]
  recommendationsDetailed DeviationRecommendation[]
  assignments       DeviationAssignment[]
  comments          DeviationComment[]

  @@index([nodeId])
  @@index([createdById])
  @@index([status])
}

// ============================================================================
// DETAILED HAZOP ANALYSIS TABLES (Optional structured data)
// ============================================================================

model DeviationCause {
  id          String   @id @default(cuid())
  deviationId String
  description String
  category    String?  // Human, Equipment, Process, External
  createdAt   DateTime @default(now())

  deviation Deviation @relation(fields: [deviationId], references: [id], onDelete: Cascade)

  @@index([deviationId])
}

model DeviationConsequence {
  id          String   @id @default(cuid())
  deviationId String
  description String
  category    String?  // Safety, Environmental, Operational, Economic
  severity    String?  // Minor, Moderate, Major, Critical
  createdAt   DateTime @default(now())

  deviation Deviation @relation(fields: [deviationId], references: [id], onDelete: Cascade)

  @@index([deviationId])
}

model DeviationSafeguard {
  id            String   @id @default(cuid())
  deviationId   String
  description   String
  type          String?  // Preventive, Detective, Mitigative
  effectiveness String?  // Low, Medium, High
  existing      Boolean  @default(true)
  createdAt     DateTime @default(now())

  deviation Deviation @relation(fields: [deviationId], references: [id], onDelete: Cascade)

  @@index([deviationId])
}

model DeviationRecommendation {
  id          String   @id @default(cuid())
  deviationId String
  description String
  type        String?  // Engineering, Administrative, PPE, Monitoring
  priority    String?  // Low, Medium, High, Critical
  status      RecommendationStatus @default(OPEN)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deviation Deviation @relation(fields: [deviationId], references: [id], onDelete: Cascade)

  @@index([deviationId])
}

enum RecommendationStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DeviationStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ACCEPTED
  CLOSED
}
// ============================================================================
// DEVIATION ASSIGNMENTS & COLLABORATION
// ============================================================================

model DeviationAssignment {
  id           String   @id @default(cuid())
  deviationId  String
  userId       String
  assignedById String   // Who assigned this
  role         AssignmentRole @default(RESPONSIBLE) // RESPONSIBLE or REVIEWER
  dueDate      DateTime?
  status       AssignmentStatus @default(PENDING)
  notes        String?  // Assignment notes
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deviation    Deviation @relation(fields: [deviationId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([deviationId, userId, role])
  @@index([deviationId])
  @@index([userId])
  @@index([status])
}

enum AssignmentRole {
  RESPONSIBLE  // Person responsible for resolving
  REVIEWER     // Person reviewing the resolution
}

enum AssignmentStatus {
  PENDING      // Not started
  ACCEPTED     // User accepted the assignment
  IN_PROGRESS  // Working on it
  COMPLETED    // User marked as done
  REJECTED     // User rejected the assignment
}

model DeviationComment {
  id          String   @id @default(cuid())
  deviationId String
  userId      String
  content     String   // Comment text, supports mentions @user
  parentId    String?  // For threaded replies
  edited      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deviation   Deviation         @relation(fields: [deviationId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      DeviationComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     DeviationComment[] @relation("CommentReplies")

  @@index([deviationId])
  @@index([userId])
  @@index([parentId])
}

// ============================================================================
// ACTIVITY LOGGING & NOTIFICATIONS
// ============================================================================

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  projectId      String?
  userId         String   // Who performed the action
  action         ActivityAction
  entityType     String   // Project, Node, Deviation, Comment, etc.
  entityId       String   // ID of the affected entity
  metadata       String?  // JSON string with additional context
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

enum ActivityAction {
  // Project actions
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_DELETED
  PROJECT_STATUS_CHANGED
  
  // Node actions
  NODE_CREATED
  NODE_UPDATED
  NODE_DELETED
  
  // Deviation actions
  DEVIATION_CREATED
  DEVIATION_UPDATED
  DEVIATION_DELETED
  DEVIATION_STATUS_CHANGED
  DEVIATION_ASSIGNED
  DEVIATION_UNASSIGNED
  DEVIATION_RISK_ASSESSED
  
  // Comment actions
  COMMENT_CREATED
  COMMENT_UPDATED
  COMMENT_DELETED
  
  // Team actions
  MEMBER_INVITED
  MEMBER_JOINED
  MEMBER_LEFT
  MEMBER_ROLE_CHANGED
}

model NotificationPreference {
  id                    String  @id @default(cuid())
  userId                String  @unique
  emailOnAssignment     Boolean @default(true)
  emailOnComment        Boolean @default(true)
  emailOnMention        Boolean @default(true)
  emailOnStatusChange   Boolean @default(true)
  emailOnDueDateApproaching Boolean @default(true)
  emailDigest           Boolean @default(false)
  emailDigestFrequency  String  @default("daily") // daily, weekly, never

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}